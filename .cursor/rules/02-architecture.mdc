## Database Schema

```sql
-- Core table: all user input lives here
CREATE TABLE entries (
  id               uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  raw_input        text,                    -- original voice transcript or typed text
  domain           text NOT NULL,           -- health | task | learning | idea | note
  title            text NOT NULL,
  description      text,
  metadata         jsonb,                   -- domain-specific fields (see domains doc)
  priority         text DEFAULT 'medium',  -- high | medium | low
  status           text DEFAULT 'pending', -- pending | done | archived | snoozed
  is_recurring     boolean DEFAULT false,
  recurrence_rule  text,                   -- cron string: "0 8,13,20 * * *"
  due_at           timestamptz,
  expires_at       timestamptz,            -- for ephemeral notes (null = no expiry)
  last_reviewed_at timestamptz,            -- for spaced repetition
  created_at       timestamptz DEFAULT now(),
  updated_at       timestamptz DEFAULT now()
);

-- Push notification scheduling
CREATE TABLE reminders (
  id               uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  entry_id         uuid REFERENCES entries(id) ON DELETE CASCADE,
  fire_at          timestamptz NOT NULL,
  sent_at          timestamptz,            -- null = not yet sent
  acknowledged_at  timestamptz            -- null = not yet acted on
);

-- Daily AI briefing
CREATE TABLE briefings (
  id            uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  content       text NOT NULL,             -- AI-generated narrative text
  date          date UNIQUE NOT NULL,      -- one per day
  generated_at  timestamptz DEFAULT now()
);

-- RLS: enable on all tables, policy = auth.uid() owns all rows
ALTER TABLE entries ENABLE ROW LEVEL SECURITY;
ALTER TABLE reminders ENABLE ROW LEVEL SECURITY;
ALTER TABLE briefings ENABLE ROW LEVEL SECURITY;
```

